# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon / public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# service_role / secret key — ONLY used in the admin dashboard (password-protected)
# ⚠️  In production, move admin writes to a Supabase Edge Function so this key
#     is never in the browser bundle.
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here
