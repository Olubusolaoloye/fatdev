# ── WalletConnect / Reown ─────────────────────────────────────────────────────
# 1. Go to https://dashboard.reown.com and create a project
# 2. In your project → Domains → add:
#    - localhost        (for local dev)
#    - your-app.netlify.app  (for production)
#    - yourdomain.com   (if using a custom domain)
# 3. Copy the Project ID here:
VITE_WALLETCONNECT_PROJECT_ID=your-reown-project-id

# Your app's public URL — must exactly match a domain in the Reown allowlist
# Local dev:  http://localhost:5173
# Production: https://your-app.netlify.app  or  https://yourdomain.com
VITE_APP_URL=http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon / public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# service_role / secret key — ONLY used in the admin dashboard (password-protected)
# ⚠️  In production, move admin writes to a Supabase Edge Function so this key
#     is never in the browser bundle.
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here
