# WalletConnect / Reown — get project ID at https://dashboard.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Your app's public URL
VITE_APP_URL=https://fatdev.io

# Supabase (needed for admin dashboard and tier storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_SERVICE_KEY — keep out of source; admin-only, never expose to end users

# ── Robinhood Chain ──────────────────────────────────────────────────────────
# Alchemy/QuickNode mainnet endpoint for Robinhood Chain (chain 4663)
# Blank = public fallback https://rpc.mainnet.chain.robinhood.com (rate-limited)
VITE_ROBINHOOD_RPC_URL=

# ── LI.FI Bridge integrator fee ──────────────────────────────────────────────
# Decimal fraction, e.g. 0.003 for 0.3%. Defaults to 0 (no fee).
# Fee collection requires partner-portal approval at https://li.fi/partners
# Until approved, this value silently does nothing even if non-zero.
VITE_LIFI_FEE=0
